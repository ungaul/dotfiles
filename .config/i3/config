set $mod Mod4
set $alt Mod1
set $refresh_i3status killall -SIGUSR1 i3status

exec --no-startup-id xrandr --output eDP1 --primary --auto --output HDMI2 --auto --right-of eDP1
exec --no-startup-id rofi -show drun -no-lazy-grab &>/dev/null &
exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id xss-lock --transfer-sleep-lock -- betterlockscreen -l --nofork
exec --no-startup-id pipewire
exec --no-startup-id /usr/lib/xdg-desktop-portal &
exec --no-startup-id /usr/lib/xdg-desktop-portal-gtk &
exec --no-startup-id dunst &
exec --no-startup-id ~/.config/eww/scripts/notif-logger.sh
exec --no-startup-id setxkbmap fr
exec --no-startup-id greenclip daemon
exec --no-startup-id xrdb ~/.Xresources
exec --no-startup-id sleep 4 && autotiling
exec --no-startup-id localsend --hidden
exec --no-startup-id alttab -bg "#1a1d15" -fg "#d6d0bd" -frame "#c9b98f" -inact "#2f3327" -t 150x100 -d 1
# exec --no-startup-id discord --start-minimized
exec_always --no-startup-id ~/.config/polybar/launch.sh

font pango:monospace 10
floating_modifier $mod
tiling_drag modifier titlebar
focus_follows_mouse yes
mouse_warping output

bindsym $mod+Shift+s exec maim -s | xclip -selection clipboard -t image/png
bindsym $mod+t exec alacritty
bindsym $mod+q kill
bindsym $mod+l exec ~/.config/i3/powermenu.sh
bindsym Control+Mod1+Delete exec ~/.config/i3/powermenu.sh
bindsym Control+Shift+Escape exec plasma-systemmonitor
bindsym $mod+e exec nautilus
bindsym $mod+v exec rofi -modi "clipboard:greenclip print" -show clipboard -run-command '{cmd}'
bindsym $mod+Left focus left
bindsym $mod+Right focus right
bindsym $mod+Shift+Left exec --no-startup-id ~/.config/i3/ws-nav.sh move prev
bindsym $mod+Shift+Right exec --no-startup-id ~/.config/i3/ws-nav.sh move next

# Scroll to switch/move workspaces, wrapping within the fixed 5 workspaces
bindsym $mod+button4 exec --no-startup-id ~/.config/i3/ws-nav.sh switch prev
bindsym $mod+button5 exec --no-startup-id ~/.config/i3/ws-nav.sh switch next
bindsym $mod+Shift+button4 exec --no-startup-id ~/.config/i3/ws-nav.sh move prev
bindsym $mod+Shift+button5 exec --no-startup-id ~/.config/i3/ws-nav.sh move next
# bindsym .$mod+d exec --no-startup-id rofi -show drun

# exec --no-startup-id i3-msg "i3-msg "workspace 2; exec alacritty --title ws-placeholder" && i3-msg "workspace 3; exec alacritty --title ws-placeholder" && i3-msg "workspace 4; exec alacritty --title ws-placeholder" && i3-msg "workspace 5; exec alacritty --title ws-placeholder" && i3-msg "workspace 1"
for_window [title="ws-placeholder"] floating enable

# Claude Code quick-access floating panel, pinned to the left edge
for_window [instance="claude-menu"] floating enable, sticky enable, border pixel 0, resize set 300 px 770 px, move position 0 0, move scratchpad, scratchpad show
bindsym $mod+b exec --no-startup-id ~/.config/i3/claude-menu.sh

# eww control panel, pinned to the right edge
for_window [title="rightpanel"] floating enable, border pixel 0, resize set 306 px 774 px, move position 974 0
bindsym $mod+n exec --no-startup-id ~/.config/i3/rightpanel.sh

exec --no-startup-id xcape -e 'Super_L=Alt_L|F1' -t 150
bindsym Mod1+F1 exec --no-startup-id rofi -show drun
# bindsym $mod+d exec --no-startup-id rofi -show drun

# Screenshots
bindcode --release 70 exec --no-startup-id sh -c 'mkdir -p "$HOME/pictures/screenshots" && file="$HOME/pictures/screenshots/$(date +%Y-%m-%d_%H-%M-%S).png" && maim "$file" && xclip -selection clipboard -t image/png -i "$file"'
bindcode --release Shift+70 exec --no-startup-id sh -c 'mkdir -p "$HOME/pictures/screenshots" && file="$HOME/pictures/screenshots/$(date +%Y-%m-%d_%H-%M-%S).png" && geom="$(slop -f "%g")" && maim -g "$geom" "$file" && xclip -selection clipboard -t image/png -i "$file"'

# Gaps
gaps inner 6
gaps outer -2
smart_gaps off

# move focused window
bindsym $mod+Shift+j move left
bindsym $mod+Shift+k move down
bindsym $mod+Shift+l move up
bindsym $mod+Shift+semicolon move right

# OSD
bindcode 121 exec --no-startup-id ~/.config/i3/volume.sh mute
bindcode 122 exec --no-startup-id ~/.config/i3/volume.sh down
bindcode 123 exec --no-startup-id ~/.config/i3/volume.sh up
bindcode 232 exec --no-startup-id ~/.config/i3/brightness.sh down
bindcode 233 exec --no-startup-id ~/.config/i3/brightness.sh up

# Remove title bars
default_border pixel 2
default_floating_border pixel 2

mode "resize" {
    bindsym Left  resize shrink width 10 px
    bindsym Down  resize grow height 10 px
    bindsym Up    resize shrink height 10 px
    bindsym Right resize grow width 10 px
    bindsym Return mode "default"
    bindsym Escape mode "default"
}

exec_always --no-startup-id feh --bg-fill $HOME/Pictures/Images/Aesthetic/Wallpapers/wallpaper_final.png

bindsym $mod+r mode "resize"
bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent
bindsym $mod+d focus child

# Define names for default workspaces for which we configure key bindings later on.
# We use variables to avoid repeating the names in multiple places.
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart

# Window border colors — earthy matte theme
client.focused          #9aac6f #1a1d15 #ded6c2 #b59a62 #9aac6f
client.focused_inactive #4a4d3d #1a1d15 #c8c0aa #4a4d3d #4a4d3d
client.unfocused        #2f3327 #10120d #8f8875 #2f3327 #2f3327
client.urgent           #9b5f50 #211b14 #eee4cb #9b5f50 #9b5f50
client.placeholder      #181a14 #10120d #d6d0bd #181a14 #181a14

